{
  "name": "@exon-cli/core",
  "version": "1.0.4",
  "description": "Core utilities and engine for Exon CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "exon",
    "cli",
    "typescript",
    "node",
    "generator"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "fs-extra": "^11.3.2",
    "giget": "^3.2.0",
    "picocolors": "^1.1.1",
    "ts-morph": "^21.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
