{
  "templates": {
    "node-express-template-ts": {
      "repo": "arpitbhatia23/exon-cli",
      "path": "templates/node-express-template-ts"
    },
    "node-express-template-js": {
      "repo": "arpitbhatia23/exon-cli",
      "path": "templates/node-express-template-js"
    }
  },
  "plugins": {
    "swagger": {
      "name": "swagger",
      "type": "feature",
      "condition": {
        "field": "options.swagger",
        "truthy": true
      },
      "asset": [
        {
          "source": "src/swagger.config.{ext}",
          "destination": "src/swagger.config.{ext}",
          "overwrite": true
        }
      ],
      "templatePath": "plugins/templates/swagger",
      "files": ["swagger.config.{ext}", "swagger.config.{ext}"],
      "dependencies": {
        "swagger-ui-express": "latest",
        "swagger-jsdoc": "latest"
      },
      "devDependencies": {
        "@types/swagger-ui-express": "latest",
        "@types/swagger-jsdoc": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/app.{ext}",
          "moduleSpecifier": "./swagger.config.{ext}",
          "namedImports": ["swaggerSpec"]
        },
        {
          "type": "import",
          "file": "src/app.{ext}",
          "moduleSpecifier": "swagger-ui-express",
          "defaultImport": "swaggerUi"
        },
        {
          "type": "statement",
          "file": "src/app.{ext}",
          "after": "app.use(cookieParser());",
          "code": "app.use(\"/docs\", swaggerUi.serve, swaggerUi.setup(swaggerSpec));"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "type": "import",
            "file": "src/app.{ext}",
            "moduleSpecifier": "./swagger.config.{ext}",
            "namedImports": ["swaggerSpec"]
          },
          {
            "type": "import",
            "file": "src/app.{ext}",
            "moduleSpecifier": "swagger-ui-express",
            "defaultImport": "swaggerUi"
          }
        ],
        "removeStatements": [
          {
            "type": "statement",
            "file": "src/app.{ext}",
            "after": "app.use(cookieParser());",
            "code": "app.use(\"/docs\", swaggerUi.serve, swaggerUi.setup(swaggerSpec));"
          }
        ]
      }
    },
    "prisma": {
      "name": "prisma",
      "type": "database",
      "condition": {
        "field": "options.database",
        "equals": "prisma"
      },
      "asset": [
        {
          "source": "./index.{ext}",
          "destination": "src/db/index.{ext}",
          "overwrite": true
        },
        {
          "source": "./schema.prisma",
          "destination": "src/prisma/schema.prisma",
          "overwrite": true
        }
      ],
      "templatePath": "plugins/templates/prisma",
      "files": [
        "src/db/index.ts",
        "src/db/index.js",
        "src/prisma/schema.prisma"
      ],
      "dependencies": {
        "@prisma/client": "latest"
      },
      "devDependencies": {
        "prisma": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/index.{ext}",
          "moduleSpecifier": "./db/index.{ext}",
          "namedImports": ["connectDB"]
        },
        {
          "type": "statement",
          "file": "src/index.{ext}",
          "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
          "code": "await connectDB();"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "type": "import",
            "file": "src/index.{ext}",
            "moduleSpecifier": "./db/index.{ext}",
            "namedImports": ["connectDB"]
          }
        ],
        "removeStatements": [
          {
            "type": "statement",
            "file": "src/index.{ext}",
            "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
            "code": "await connectDB();"
          }
        ]
      }
    },
    "mongoose": {
      "name": "mongoose",
      "type": "database",
      "condition": [
        {
          "field": "options.database",
          "equals": "Mongoose"
        }
      ],
      "asset": [
        {
          "source": "./index.{ext}",
          "destination": "src/db/index.{ext}",
          "overwrite": true
        }
      ],
      "templatePath": "plugins/templates/mongoose",
      "files": ["src/db/index.{ext}", "src/db/index.{ext}"],

      "dependencies": {
        "mongoose": "latest"
      },
      "devDependencies": {
        "@types/mongoose": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/index.{ext}",
          "moduleSpecifier": "./db/index.{ext}",
          "namedImports": ["connectDB"]
        },
        {
          "type": "statement",
          "file": "src/index.{ext}",
          "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
          "code": "await connectDB();"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "file": "src/db/index.{ext}",
            "moduleSpecifier": "mongoose",
            "defaultImport": "mongoose"
          },
          {
            "file": "src/index.{ext}",
            "moduleSpecifier": "./db/index.{ext}",
            "namedImports": ["connectDB"]
          }
        ],
        "removeStatements": [
          {
            "type": "statement",
            "file": "src/index.{ext}",
            "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
            "code": "await connectDB();"
          }
        ]
      }
    },
    "logger": {
      "name": "logger",
      "type": "utility",
      "condition": {
        "field": "options.logger",
        "truthy": true
      },
      "asset": [
        {
          "source": "src/middleware/morgan.middleware.{ext}",
          "destination": "src/middleware/morgan.middleware.{ext}",
          "overwrite": true
        },
        {
          "source": "src/utils/logger.{ext}",
          "destination": "src/utils/logger.{ext}",
          "overwrite": true
        }
      ],
      "templatePath": "plugins/templates/logger",
      "files": [
        "src/middleware/morgan.middleware.ts",
        "src/middleware/morgan.middleware.js",
        "src/utils/logger.ts",
        "src/utils/logger.js"
      ],
      "dependencies": {
        "winston": "latest",
        "morgan": "latest",
        "winston-daily-rotate-file": "latest"
      },
      "devDependencies": {
        "@types/winston": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/app.{ext}",
          "moduleSpecifier": "src/middleware/morgan.middleware.{ext}",
          "defaultImport": "morganLogger"
        },
        {
          "type": "import",
          "file": "src/utils/asyncHandler.{ext}",
          "moduleSpecifier": "./logger.{ext}",
          "defaultImport": "logger"
        },
        {
          "type": "statement",
          "file": "src/utils/asyncHandler.{ext}",
          "after": "const message = error.message || \"Something went wrong\";",
          "code": "logger.error(error);"
        },
        {
          "type": "statement",
          "file": "src/app.{ext}",
          "after": "app.use(cookieParser());",
          "code": "app.use(morganLogger);"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "type": "import",
            "file": "src/app.{ext}",
            "moduleSpecifier": "./middleware/morgan.middleware.{ext}",
            "defaultImport": "morganLogger"
          },
          {
            "type": "import",
            "file": "src/utils/asyncHandler.{ext}",
            "moduleSpecifier": "./logger.{ext}",
            "defaultImport": "logger"
          }
        ],
        "removeStatements": [
          {
            "type": "statement",
            "file": "src/utils/asyncHandler.{ext}",
            "after": "const message = error.message || \"Something went wrong\";",
            "code": "logger.error(error);"
          },
          {
            "type": "statement",
            "file": "src/app.{ext}",
            "after": "app.use(cookieParser());",
            "code": "app.use(morganLogger);"
          }
        ]
      }
    },
    "docker": {
      "name": "docker",
      "type": "deployment",
      "condition": {
        "field": "options.docker",
        "truthy": true
      },
      "templatePath": "plugins/templates/docker",
      "files": [
        "packages/plugins/docker/index.ts",
        "packages/plugins/docker/dockerHelper.ts"
      ],
      "dependencies": {},
      "devDependencies": {},
      "inject": [],
      "uninstall": {
        "removeImports": [],
        "removeStatements": []
      }
    },
    "socket": {
      "name": "socket",
      "type": "realtime",
      "condition": {
        "field": "options.socket",
        "truthy": true
      },
      "asset": [
        {
          "source": "./index.{ext}",
          "destination": "src/socket/index.{ext}",
          "overwrite": true
        }
      ],
      "templatePath": "plugins/templates/socket",
      "files": ["src/socket/index.js", "src/socket/index.ts"],

      "dependencies": {
        "socket.io": "latest"
      },
      "devDependencies": {
        "@types/socket.io": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/app.{ext}",
          "moduleSpecifier": "http",
          "defaultImport": "http"
        },
        {
          "type": "import",
          "file": "src/app.{ext}",
          "moduleSpecifier": "./socket/index.{ext}",
          "namedImports": "initSocket"
        },
        {
          "type": "replaceImport",
          "file": "src/index.{ext}",
          "moduleSpecifier": "./app.{ext}",
          "from": "app",
          "to": "server"
        },
        {
          "type": "statement",
          "file": "src/app.{ext}",
          "after": "app.use(cookieParser());",
          "code": "const server = http.createServer(app); \n initSocket(server);"
        },
        {
          "type": "replaceCall",
          "file": "src/index.{ext}",
          "target": "app.listen",
          "replaceWith": "server.listen"
        },
        {
          "type": "replaceExport",
          "file": "src/app.{ext}",
          "from": "app",
          "to": "server"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "type": "import",
            "file": "src/app.{ext}",
            "moduleSpecifier": "http",
            "defaultImport": "http"
          },
          {
            "type": "import",
            "file": "src/app.{ext}",
            "moduleSpecifier": "./socket/index.{ext}",
            "namedImports": ["initSocket"]
          }
        ],
        "removeStatements": [
          {
            "type": "statement",
            "file": "src/app.{ext}",
            "after": "app.use(cookieParser());",
            "code": "const server = http.createServer(app); \n initSocket(server);"
          }
        ],
        "replaceCalls": [
          {
            "type": "replaceCall",
            "file": "src/index.{ext}",
            "target": "server.listen",
            "replaceWith": "app.listen"
          }
        ],
        "replaceImport": [
          {
            "type": "replaceExport",
            "file": "src/index.{ext}",
            "moduleSpecifier": "./app.{ext}",
            "from": "server",
            "to": "app"
          }
        ],
        "replaceExports": [
          {
            "type": "replaceExport",
            "file": "src/app.{ext}",
            "from": "server",
            "to": "app"
          }
        ]
      }
    },
    "drizzle": {
      "name": "drizzle",
      "type": "database",
      "condition": {
        "field": "options.database",
        "equals": "drizzle"
      },
      "asset": [
        {
          "source": "./index.{ext}",
          "destination": "src/db/index.{ext}",
          "overwrite": true
        },
        {
          "source": "./drizzle.config.{ext}",
          "destination": "src/drizzle.config.{ext}",
          "overwrite": true
        }
      ],
      "templatePath": "plugins/templates/drizzle",
      "files": [
        "src/db/index.js",
        "src/db/index.ts",
        "src/drizzle.config.ts",
        "src/drizzle.config.js"
      ],
      "dependencies": {
        "drizzle-orm": "latest",
        "pg": "latest"
      },
      "devDependencies": {
        "drizzle-kit": "latest",
        "@types/pg": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/index.{ext}",
          "moduleSpecifier": "./db/index.{ext}",
          "namedImports": ["connectDB"]
        },
        {
          "type": "statement",
          "file": "src/index.{ext}",
          "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
          "code": "await connectDB();"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "type": "import",
            "file": "src/index.{ext}",
            "moduleSpecifier": "./db/index.{ext}",
            "namedImports": ["connectDB"]
          }
        ],
        "removeStatements": [
          {
            "type": "statement",
            "file": "src/index.{ext}",
            "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
            "code": "await connectDB();"
          }
        ]
      }
    }
  }
}
