{
  "templates": {
    "node-express-template-ts": {
      "repo": "arpitbhatia23/exon-cli",
      "path": "templates/node-express-template-ts"
    },
    "node-express-template-js": {
      "repo": "arpitbhatia23/exon-cli",
      "path": "templates/node-express-template-js"
    }
  },
  "plugins": {
    "swagger": {
      "name": "swagger",
      "type": "feature",
      "condition": {
        "field": "options.swagger",
        "truthy": true
      },

      "templatePath": "plugins/templates/swagger",
      "files": ["swagger.config.{ext}", "swagger.config.{ext}"],
      "dependencies": {
        "swagger-ui-express": "latest",
        "swagger-jsdoc": "latest"
      },
      "devDependencies": {
        "@types/swagger-ui-express": "latest",
        "@types/swagger-jsdoc": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/app.{ext}",
          "moduleSpecifier": "./swagger.config.{ext}",
          "namedImports": ["swaggerSpec"]
        },
        {
          "type": "import",
          "file": "src/app.ts",
          "moduleSpecifier": "swagger-ui-express",
          "defaultImport": "swaggerUi"
        },
        {
          "type": "statement",
          "file": "src/app.ts",
          "after": "const app = express();",
          "code": "app.use(\"/docs\", swaggerUi.serve, swaggerUi.setup(swaggerSpec));"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "file": "src/app.ts",
            "moduleSpecifier": "./swagger.config.{ext}",
            "namedImports": ["swaggerSpec"]
          },
          {
            "file": "src/app.ts",
            "moduleSpecifier": "swagger-ui-express",
            "defaultImport": "swaggerUi"
          }
        ],
        "removeStatements": [
          {
            "file": "src/app.{ext}",
            "code": "app.use(\"/docs\", swaggerUi.serve, swaggerUi.setup(swaggerSpec));"
          }
        ]
      }
    },
    "prisma": {
      "name": "prisma",
      "type": "database",
      "condition": {
        "field": "options.database",
        "equals": "prisma"
      },
      "templatePath": "plugins/templates/prisma",
      "files": ["src/db/index.ts", "src/db/index.js", "src/db/schema.prisma"],
      "dependencies": {
        "@prisma/client": "latest"
      },
      "devDependencies": {
        "prisma": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/app.ts",
          "moduleSpecifier": "./prisma.config.js",
          "namedImports": ["prisma"]
        },
        {
          "type": "statement",
          "file": "src/app.ts",
          "after": "const app = express();",
          "code": "app.use((req, res, next) => { req.prisma = prisma; next(); });"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "file": "src/app.ts",
            "moduleSpecifier": "./prisma.config.js",
            "namedImports": ["prisma"]
          }
        ],
        "removeStatements": [
          {
            "file": "src/app.ts",
            "code": "app.use((req, res, next) => { req.prisma = prisma; next(); });"
          }
        ]
      }
    },
    "mongoose": {
      "name": "mongoose",
      "type": "database",
      "condition": [
        {
          "field": "options.database",
          "equals": "Mongoose"
        }
      ],
      "asset": [
        {
          "source": "./index.{ext}",
          "destination": "src/db/index.{ext}",
          "overwrite": true
        }
      ],
      "templatePath": "plugins/templates/mongoose",
      "files": ["src/db/index.{ext}", "src/db/index.{ext}"],

      "dependencies": {
        "mongoose": "latest"
      },
      "devDependencies": {
        "@types/mongoose": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/app.{ext}",
          "moduleSpecifier": "src/db/index.{ext}",
          "namedImport": ["connectDB"]
        },
        {
          "type": "statement",
          "file": "src/index.ts",
          "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
          "code": "await connectDB();"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "file": "src/db/index.{ext}",
            "moduleSpecifier": "mongoose",
            "defaultImport": "mongoose"
          },
          {
            "file": "src/index.{ext}",
            "moduleSpecifier": "./db",
            "namedImports": ["connectDB"]
          }
        ],
        "removeStatements": [
          {
            "type": "statement",
            "file": "src/index.ts",
            "after": "const port: number = process.env.PORT ? Number(process.env.PORT) : 3802;",
            "code": "await connectDB();"
          }
        ]
      }
    },
    "logger": {
      "name": "logger",
      "type": "utility",
      "condition": {
        "field": "options.logger",
        "truthy": true
      },
      "templatePath": "plugins/templates/logger",
      "files": [
        "src/middleware/morgan.middleware.ts",
        "src/middleware/morgan.middleware.js",
        "src/utils/logger.ts",
        "src/utils/logger.js"
      ],
      "dependencies": {
        "winston": "latest",
        "morgan": "latest",
        "winston-daily-rotate-file": "latest"
      },
      "devDependencies": {
        "@types/winston": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/app.ts",
          "moduleSpecifier": "./config/logger.config",
          "namedImports": ["logger"]
        },
        {
          "type": "import",
          "file": "src/app.ts",
          "moduleSpecifier": "morgan",
          "defaultImport": "morgan"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "file": "src/app.ts",
            "moduleSpecifier": "./config/logger.config",
            "namedImports": ["logger"]
          },
          {
            "file": "src/app.ts",
            "moduleSpecifier": "morgan",
            "defaultImport": "morgan"
          }
        ]
      }
    },
    "docker": {
      "name": "docker",
      "type": "deployment",
      "condition": {
        "field": "options.docker",
        "truthy": true
      },
      "templatePath": "plugins/templates/docker",
      "files": [
        "packages/plugins/docker/index.ts",
        "packages/plugins/docker/dockerHelper.ts"
      ],
      "dependencies": {},
      "devDependencies": {},
      "inject": [],
      "uninstall": {
        "removeImports": [],
        "removeStatements": []
      }
    },
    "socket": {
      "name": "socket",
      "type": "realtime",
      "condition": {
        "field": "options.socket",
        "truthy": true
      },
      "templatePath": "plugins/templates/socket",
      "files": ["src/socket/index.js", "src/socket/index.ts"],

      "dependencies": {
        "socket.io": "latest"
      },
      "devDependencies": {
        "@types/socket.io": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/index.ts",
          "moduleSpecifier": "socket.io",
          "defaultImport": "socketIo"
        },
        {
          "type": "statement",
          "file": "src/index.ts",
          "after": "const io = socketIo(server);",
          "code": "io.on('connection', (socket) => { console.log('New client connected'); });"
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "file": "src/index.ts",
            "moduleSpecifier": "socket.io",
            "defaultImport": "socketIo"
          }
        ],
        "removeStatements": [
          {
            "file": "src/index.ts",
            "code": "io.on('connection', (socket) => { console.log('New client connected'); });"
          }
        ]
      }
    },
    "drizzle": {
      "name": "drizzle",
      "type": "database",
      "condition": {
        "field": "options.database",
        "equals": "drizzle"
      },
      "templatePath": "plugins/templates/drizzle",
      "files": [
        "src/db/index.js",
        "srx/db/index.ts",
        "drizzle.config.ts",
        "drizzle.config.js"
      ],
      "dependencies": {
        "drizzle-orm": "latest",
        "drizzle-kit": "latest"
      },
      "devDependencies": {
        "@types/drizzle-orm": "latest"
      },
      "inject": [
        {
          "type": "import",
          "file": "src/db/index.ts",
          "moduleSpecifier": "drizzle-orm",
          "namedImports": ["drizzle"]
        },
        {
          "type": "import",
          "file": "src/db/index.ts",
          "moduleSpecifier": "../schema.js",
          "namedImports": ["schema"]
        }
      ],
      "uninstall": {
        "removeImports": [
          {
            "file": "src/db/index.ts",
            "moduleSpecifier": "drizzle-orm",
            "namedImports": ["drizzle"]
          },
          {
            "file": "src/db/index.ts",
            "moduleSpecifier": "../schema.js",
            "namedImports": ["schema"]
          }
        ]
      }
    }
  }
}
