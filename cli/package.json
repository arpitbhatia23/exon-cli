{
  "name": "exon-cli",
  "version": "3.0.2",
  "description": "Production-ready Express.js backend generator. Scaffolds TypeScript/JavaScript projects with patterns for Prisma, Drizzle, Mongoose, and more.",
  "main": "./dist/index.js",
  "bin": {
    "exon-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/index.js",
    "test": "npx tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write"
  },
  "keywords": [
    "express typescript starter",
    "express boilerplate",
    "nodejs api starter",
    "express generator alternative",
    "express production starter",
    "node backend starter",
    "rest api generator",
    "express cli tool",
    "backend scaffold tool",
    "express swagger starter",
    "nodejs boilerplate",
    "typescript express boilerplate",
    "express api template",
    "backend starter template",
    "express project generator",
    "nodejs rest api boilerplate",
    "express best practices",
    "express starter kit",
    "api scaffold cli",
    "express production setup"
  ],
  "author": {
    "name": "Arpit Bhatia",
    "email": "aurpitaurpit@gmail.com",
    "url": "https://github.com/arpitbhatia23"
  },
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/arpitbhatia23/exon-cli.git"
  },
  "bugs": {
    "url": "https://github.com/arpitbhatia23/exon-cli/issues",
    "email": "aurpitaurpit@gmail.com"
  },
  "homepage": "https://personal-580f42c0.mintlify.app/",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@exon-cli/core": "1.0.2",
    "@types/commander": "^2.12.0",
    "@types/fs-extra": "^11.0.4",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "figlet": "^1.9.4",
    "fs-extra": "^11.3.2",
    "giget": "^3.2.0",
    "picocolors": "^1.1.1",
    "ts-morph": "^21.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
